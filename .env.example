# FormBackend API — Configuration
# Copy to .env and edit for your deployment

# Security (change this in production!)
SECRET_KEY=change-me-to-a-random-secret-in-production

# Database (defaults match docker-compose.yml)
DATABASE_URL=postgresql://formbackend:formbackend@postgres:5432/formbackend

# Redis
REDIS_URL=redis://redis:6379/0

# SMTP (optional — needed for magic link emails)
# SMTP_HOST=smtp.example.com
# SMTP_USER=user@example.com
# SMTP_PASS=your-password

# Cloudflare Turnstile (anti-spam) — dev keys pass all challenges
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=1x0000000000000000000000000000000AA
