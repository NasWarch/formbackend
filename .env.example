# ============================================================
# Monetization Lab — Configuration (copier vers .env)
# ============================================================

# Application
APP_NAME=FormAPI
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-in-production
ENVIRONMENT=development

# Database (PostgreSQL — déjà sur l'hôte)
DATABASE_URL=postgresql://postgres:***@localhost:5432/monetization

# Redis (déjà sur l'hôte)
REDIS_URL=redis://localhost:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# Rate limiting
RATE_LIMIT=60/minute

# CORS — séparés par des virgules
CORS_ORIGINS=http://localhost:8000
